OPENAI_API_KEY=sk-your-key-here
# Required for LLM agent reasoning (ReAct loop).
# If not set, agent falls back to rule-based policy — still fully functional.

# Optional: max autonomous remediation actions per episode (default: 3)
# AIOPS_MAX_ACTIONS=3

# Optional: behavior when action budget is exhausted and anomaly persists.
# Allowed: continue_monitoring (default) | alert_human
# AIOPS_BUDGET_EXHAUSTED_ACTION=continue_monitoring
