OPENAI_API_KEY=sk-your-key-here
# Required for LLM agent reasoning (ReAct loop).
# If not set, agent falls back to rule-based policy — still fully functional.

# Optional: max autonomous remediation actions per episode (default: 3)
# AIOPS_MAX_ACTIONS=3

# Optional: behavior when action budget is exhausted and anomaly persists.
# Allowed: continue_monitoring (default) | alert_human
# AIOPS_BUDGET_EXHAUSTED_ACTION=continue_monitoring

# --- Live mode (Prometheus data source) ---

# Set to "live" to connect to a real Prometheus instance instead of the simulator.
# Default is "simulated" (uses built-in fault simulator for demos and benchmarks).
# AIOPS_MODE=simulated

# Prometheus server URL (required when AIOPS_MODE=live)
# PROMETHEUS_URL=http://prometheus:9090

# Path to metric map config (required when AIOPS_MODE=live)
# See config/metric_map.yaml for the format and Kubernetes query examples.
# PROMETHEUS_METRIC_MAP=config/metric_map.yaml

# How often Prometheus is scraped, in seconds (default: 15)
# PROMETHEUS_SCRAPE_INTERVAL=15

# Steps of live data to collect as a normal baseline before re-anchoring
# the anomaly detector's score normalization. Default: 180 (~30 min at 10s intervals).
# AIOPS_WARMUP_STEPS=180

# Set to "false" to let the agent execute real remediation actions.
# Default is "true" (dry run): the agent reasons and logs actions but does not act.
# Only disable after validating the agent against your infrastructure first.
# AIOPS_DRY_RUN=true

# kubectl context for Kubernetes actions (uses current context if unset)
# KUBECTL_CONTEXT=my-cluster
# KUBECTL_NAMESPACE=default

# Webhook URLs for firewall/WAF IP blocking and rate limiting
# BLOCK_IP_WEBHOOK_URL=https://your-firewall/api/block
# RATE_LIMIT_WEBHOOK_URL=https://your-gateway/api/rate-limit
